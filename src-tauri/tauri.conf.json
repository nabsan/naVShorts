{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Shorts Reels Maker",
  "version": "0.1.0",
  "identifier": "com.example.shortsreelsmaker",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Shorts/Reels Maker",
        "width": 1200,
        "height": 860,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}