{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "naVShorts",
  "version": "0.1.0",
  "identifier": "com.example.shortsreelsmaker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "naVShorts",
        "url": "/",
        "width": 1200,
        "height": 860,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}

